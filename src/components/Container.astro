---
import type { Polymorphic } from 'astro/types';

type LayoutTag = 'section' | 'div' | 'article' | 'header' | 'footer' | 'code';

type Props<Tag extends LayoutTag> = Polymorphic<{
    as: Tag;
    class?: string;
    /** Use the wider content measure for rich portfolio layouts. */
    wide?: boolean;
}>;

const {
    as: Tag = 'div',
    class: className,
    wide = false,
    ...rest
} = Astro.props as Props<LayoutTag> & Record<string, unknown>;
---

<Tag
    {...rest}
    class:list={[
        wide ? 'max-w-[68rem] mx-auto px-4 sm:px-6' : 'max-w-[40rem] mx-auto px-4',
        className,
    ]}
>
    <slot />
</Tag>
