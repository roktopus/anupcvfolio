---
// Mist Flow Background Component - Simplified for Performance
---

<!-- Scrolls with page: absolute fill of body (see global.css body position) -->
<div class="mist-bg-root" aria-hidden="true">
    <div class="stage"></div>
    <div class="sparkles">
    <!-- Fallback static sparkles for immediate visibility -->
    <div
        class="star-sparkle"
        data-sparkle="1"
        style="left: 20%; top: 30%; --star-size: 12px; --duration: 2s;"
    >
    </div>
    <div
        class="star-sparkle"
        data-sparkle="2"
        style="left: 80%; top: 20%; --star-size: 10px; --duration: 2.5s; animation-delay: 0.5s;"
    >
    </div>
    <div
        class="star-sparkle"
        data-sparkle="3"
        style="left: 60%; top: 70%; --star-size: 14px; --duration: 1.8s; animation-delay: 1s;"
    >
    </div>
    <div
        class="star-sparkle"
        data-sparkle="4"
        style="left: 40%; top: 15%; --star-size: 11px; --duration: 2.2s; animation-delay: 1.5s;"
    >
    </div>
    <div
        class="star-sparkle"
        data-sparkle="5"
        style="left: 15%; top: 80%; --star-size: 13px; --duration: 2.8s; animation-delay: 2s;"
    >
    </div>
    <div
        class="star-sparkle"
        data-sparkle="6"
        style="left: 85%; top: 60%; --star-size: 9px; --duration: 1.6s; animation-delay: 2.5s;"
    >
    </div>
    <div
        class="star-sparkle"
        data-sparkle="7"
        style="left: 50%; top: 45%; --star-size: 10px; --duration: 2s; animation-delay: 0.35s;"
    >
    </div>
    </div>

    <!-- Mist particles -->
    <div class="mist">
        <span class="particle"></span>
        <span class="particle layer2"></span>
        <span class="particle"></span>
        <span class="particle layer2"></span>
        <span class="particle"></span>
        <span class="particle layer2"></span>
    </div>
</div>

<style>
    /* Theme variables are defined on :root/.dark to avoid first-paint mismatch */
    :global(:root) {
        --bg-1: #f6f7fb;
        --bg-2: #ffffff;
        --mist-color: rgba(255, 205, 95, 0.2);
        --mist-color-2: rgba(255, 180, 70, 0.14);
        --ui-color: #6b5600;
        --spark-a: rgba(255, 200, 60, 1);
        --spark-b: rgba(255, 170, 30, 1);
    }
    :global(html.dark) {
        --bg-1: #060912;
        --bg-2: #0c1122;
        --mist-color: rgba(70, 225, 255, 0.18);
        --mist-color-2: rgba(90, 150, 255, 0.11);
        --ui-color: #9bdcff;
        --spark-a: rgba(60, 240, 255, 0.95);
        --spark-b: rgba(90, 255, 160, 0.95);
    }

    /* Fills document height; scrolls with in-flow content (not fixed to viewport). */
    .mist-bg-root {
        position: absolute;
        inset: 0;
        width: 100%;
        min-height: 100%;
        pointer-events: none;
        z-index: 0;
        overflow: hidden;
    }

    /* Gradient background layer */
    .stage {
        position: absolute;
        inset: 0;
        background: linear-gradient(to bottom, var(--bg-2), var(--bg-1));
        z-index: 1;
    }

    /* Mist layer */
    .mist {
        position: absolute;
        inset: 0;
        pointer-events: none;
        z-index: 2;
    }

    /* Mist particles — light wisps, softer blur, faster float via JS duration */
    .particle {
        position: absolute;
        width: 56vmax;
        height: 42vmax;
        background:
            radial-gradient(
                56% 44% at 42% 58%,
                rgba(0, 0, 0, 0) 0%,
                var(--mist-color) 10%,
                var(--mist-color) 18%,
                rgba(0, 0, 0, 0) 76%
            ),
            radial-gradient(
                48% 40% at 62% 46%,
                rgba(0, 0, 0, 0) 0%,
                var(--mist-color-2) 12%,
                var(--mist-color-2) 20%,
                rgba(0, 0, 0, 0) 74%
            ),
            radial-gradient(
                52% 42% at 48% 40%,
                rgba(0, 0, 0, 0) 0%,
                var(--mist-color) 14%,
                var(--mist-color) 22%,
                rgba(0, 0, 0, 0) 72%
            );
        border-radius: 50% / 60%;
        filter: blur(92px);
        animation: float linear infinite;
        animation-direction: alternate;
        opacity: 0.26;
        will-change: transform;
        contain: paint;
    }
    .particle.layer2 {
        width: 56vmax;
        height: 40vmax;
        filter: blur(128px);
        opacity: 0.18;
        animation-duration: calc(var(--dur, 120s) * 1.25);
        animation-direction: alternate;
    }

    /* Mist floating animation */
    @keyframes float {
        from {
            transform: translate3d(var(--x1), var(--y1), 0)
                rotate(var(--r1, 0deg)) scale(var(--sx1, 1), var(--sy1, 1));
        }
        to {
            transform: translate3d(var(--x2), var(--y2), 0)
                rotate(var(--r2, 22deg))
                scale(var(--sx2, 1.2), var(--sy2, 1.14));
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .particle {
            animation: none;
        }
        .star-sparkle {
            animation: none;
            opacity: 0.45;
        }
    }

    /* Stars sit above mist within .mist-bg-root; whole root stays under main (z-10). */
    .sparkles {
        position: absolute;
        inset: 0;
        pointer-events: none;
        z-index: 3;
    }

    /* Five-point star only (some old polygons were 8-point diamonds → looked square) */
    .star-sparkle {
        position: absolute;
        width: var(--star-size, 12px);
        height: var(--star-size, 12px);
        background: var(--spark-a);
        clip-path: polygon(
            50% 0%,
            61% 35%,
            98% 35%,
            68% 57%,
            79% 91%,
            50% 70%,
            21% 91%,
            32% 57%,
            2% 35%,
            39% 35%
        );
        -webkit-clip-path: polygon(
            50% 0%,
            61% 35%,
            98% 35%,
            68% 57%,
            79% 91%,
            50% 70%,
            21% 91%,
            32% 57%,
            2% 35%,
            39% 35%
        );
        opacity: 0;
        transform: translate(-50%, -50%) scale(0.8);
        animation: starFadeInOut var(--duration, 3s) ease-in-out infinite;
        filter: drop-shadow(0 0 8px var(--spark-a));
        pointer-events: none;
    }

    :global(html) .star-sparkle {
        background: #ffd700;
        filter: drop-shadow(0 0 6px #ffd700) drop-shadow(0 0 12px #ffb347);
    }

    :global(html.dark) .star-sparkle {
        background: #00ffff;
        filter: drop-shadow(0 0 6px #00ffff) drop-shadow(0 0 12px #00ff88);
    }

    @keyframes starFadeInOut {
        0% {
            opacity: 0;
            transform: translate(-50%, -50%) scale(0.5);
        }
        20% {
            opacity: 1;
            transform: translate(-50%, -50%) scale(1);
        }
        80% {
            opacity: 1;
            transform: translate(-50%, -50%) scale(1);
        }
        100% {
            opacity: 0;
            transform: translate(-50%, -50%) scale(0.5);
        }
    }
</style>

<script>
    // --------------------------
    // MIST PARTICLE SETUP
    // --------------------------
    const parts = document.querySelectorAll('.particle');
    const rand = (min: number, max: number) =>
        Math.random() * (max - min) + min;
    parts.forEach((p) => {
        const element = p as HTMLElement;
        const spread = () => rand(-0.28, 1.28) * 100 + '%';
        element.style.setProperty('--x1', spread());
        element.style.setProperty('--y1', spread());
        element.style.setProperty('--x2', spread());
        element.style.setProperty('--y2', spread());
        element.style.setProperty('--r1', rand(-8, 8) + 'deg');
        element.style.setProperty('--r2', rand(8, 22) + 'deg');
        element.style.setProperty('--sx1', rand(0.9, 1.05).toString());
        element.style.setProperty('--sy1', rand(0.9, 1.05).toString());
        element.style.setProperty('--sx2', rand(1.05, 1.2).toString());
        element.style.setProperty('--sy2', rand(1.05, 1.2).toString());
        /* Shorter cycle = faster drifting smoke */
        element.style.animationDuration = rand(28, 42) + 's';
        element.style.animationDelay = -rand(0, 22) + 's';
    });
    // --------------------------
    // Static sparkles (+1 vs original ≈ +17%, closest integer to +10%)
    // --------------------------
    function initializeSparkles() {
        const sparkles = document.querySelectorAll(
            '.star-sparkle[data-sparkle]'
        ) as NodeListOf<HTMLElement>;

        if (sparkles.length === 0) {
            return;
        }

        // Move sparkle to new position when it fades out
        function moveSparkle(sparkle: HTMLElement, index: number) {
            // Wait for the full animation cycle to complete
            const duration =
                parseFloat(sparkle.style.getPropertyValue('--duration')) * 1000;

            setTimeout(() => {
                // Stop the current animation
                sparkle.style.animation = 'none';

                // Change position while invisible
                const x = rand(10, 90);
                const y = rand(10, 90);
                sparkle.style.left = x + '%';
                sparkle.style.top = y + '%';

                // Wait a moment then restart animation
                setTimeout(() => {
                    void sparkle.offsetWidth; // Trigger reflow
                    sparkle.style.animation = `starFadeInOut ${duration / 1000}s ease-in-out infinite`;
                }, 200); // Longer delay to ensure position change is visible
            }, duration); // Wait for full animation cycle
        }

        // Start the system
        function startSparkleSystem() {
            // Set up position changes for each sparkle
            sparkles.forEach((sparkle, index) => {
                // Move each sparkle at different intervals
                function scheduleMove() {
                    const delay = rand(3000, 8000); // 3-8 seconds between moves
                    setTimeout(() => {
                        moveSparkle(sparkle, index);
                        scheduleMove();
                    }, delay);
                }
                scheduleMove();
            });
        }

        // Start the sparkle system
        startSparkleSystem();
    }

    function scheduleSparklesWhenIdle() {
        const run = () => initializeSparkles();
        if ('requestIdleCallback' in window) {
            requestIdleCallback(run, { timeout: 2000 });
        } else {
            setTimeout(run, 0);
        }
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', scheduleSparklesWhenIdle);
    } else {
        scheduleSparklesWhenIdle();
    }

    // --------------------------
    // THEME CHANGE LISTENER
    // --------------------------
    const observer = new MutationObserver((mutations) => {
        mutations.forEach((mutation) => {
            if (
                mutation.type === 'attributes' &&
                mutation.attributeName === 'class'
            ) {
                // Theme changed, update data-theme attribute
                const isDark =
                    document.documentElement.classList.contains('dark');
                const newTheme = isDark ? 'dark' : 'light';
                document.body.setAttribute('data-theme', newTheme);
            }
        });
    });

    // Start observing the document element for class changes
    observer.observe(document.documentElement, {
        attributes: true,
        attributeFilter: ['class'],
    });
</script>
