---
// Background: soft mist + Matrix-style code rain (replaces blinking stars).
// Rain is canvas-based, throttled, paused when the tab is hidden, and
// respects prefers-reduced-motion. Themed with the orange accent.
interface Props {
    /** Hide matrix rain and soften mist (article reading mode). */
    quiet?: boolean;
}

const { quiet = false } = Astro.props;
---

<!-- Scrolls with page: absolute fill of body (see global.css body position) -->
<div
    class:list={['mist-bg-root', quiet && 'mist-bg-root--quiet']}
    data-quiet={quiet ? 'true' : undefined}
    aria-hidden="true"
>
    <div class="stage"></div>

    <!-- Matrix code rain (fixed to viewport for steady ambient effect) -->
    {!quiet && <canvas class="matrix-rain"></canvas>}

    <!-- Mist particles -->
    <div class="mist">
        <span class="particle"></span>
        <span class="particle layer2"></span>
        <span class="particle"></span>
        <span class="particle layer2"></span>
        <span class="particle"></span>
        <span class="particle layer2"></span>
    </div>
</div>

<style>
    /* Theme variables are defined on :root/.dark to avoid first-paint mismatch */
    :global(:root) {
        --bg-1: #fbf7f2;
        --bg-2: #ffffff;
        --mist-color: rgba(249, 115, 22, 0.12);
        --mist-color-2: rgba(255, 176, 80, 0.08);
        --ui-color: #7a4a12;
        --spark-a: rgba(255, 170, 60, 0.9);
        --spark-b: rgba(249, 115, 22, 0.85);
    }
    :global(html.dark) {
        --bg-1: #0c0c0d;
        --bg-2: #161616;
        --mist-color: rgba(255, 138, 61, 0.12);
        --mist-color-2: rgba(255, 110, 40, 0.08);
        --ui-color: #ffb37a;
        --spark-a: rgba(255, 170, 90, 0.85);
        --spark-b: rgba(255, 138, 61, 0.8);
    }

    /* Fills document height; scrolls with in-flow content (not fixed to viewport). */
    .mist-bg-root {
        position: absolute;
        inset: 0;
        width: 100%;
        min-height: 100%;
        pointer-events: none;
        z-index: 0;
        overflow: hidden;
    }

    /* Gradient background layer */
    .stage {
        position: absolute;
        inset: 0;
        background: linear-gradient(to bottom, var(--bg-2), var(--bg-1));
        z-index: 1;
    }

    /* Matrix rain — fixed to viewport so it stays ambient while scrolling.
       Sits above the gradient/mist but below main content (root is z-0).
       Only on desktop/tablet (>=768px); mobile gets the static gradient. */
    .matrix-rain {
        position: fixed;
        inset: 0;
        width: 100vw;
        height: 100vh;
        z-index: 3;
        pointer-events: none;
        opacity: 0.9;
    }
    :global(html:not(.dark)) .matrix-rain {
        opacity: 0.55;
    }
    @media (prefers-reduced-motion: reduce) {
        .matrix-rain {
            opacity: 0.35;
        }
    }
    @media (max-width: 767px) {
        .matrix-rain,
        .mist {
            display: none;
        }
    }

    /* Article reading mode: no rain, quieter mist over static gradient. */
    .mist-bg-root--quiet .mist {
        opacity: 0.35;
    }
    .mist-bg-root--quiet .particle {
        animation: none;
        opacity: 0.12;
    }
    .mist-bg-root--quiet .particle.layer2 {
        opacity: 0.08;
    }

    /* Mist layer */
    .mist {
        position: absolute;
        inset: 0;
        pointer-events: none;
        z-index: 2;
    }

    /* Mist particles — light wisps, softer blur, faster float via JS duration */
    .particle {
        position: absolute;
        width: 56vmax;
        height: 42vmax;
        background:
            radial-gradient(
                56% 44% at 42% 58%,
                rgba(0, 0, 0, 0) 0%,
                var(--mist-color) 10%,
                var(--mist-color) 18%,
                rgba(0, 0, 0, 0) 76%
            ),
            radial-gradient(
                48% 40% at 62% 46%,
                rgba(0, 0, 0, 0) 0%,
                var(--mist-color-2) 12%,
                var(--mist-color-2) 20%,
                rgba(0, 0, 0, 0) 74%
            ),
            radial-gradient(
                52% 42% at 48% 40%,
                rgba(0, 0, 0, 0) 0%,
                var(--mist-color) 14%,
                var(--mist-color) 22%,
                rgba(0, 0, 0, 0) 72%
            );
        border-radius: 50% / 60%;
        filter: blur(92px);
        animation: float linear infinite;
        animation-direction: alternate;
        opacity: 0.26;
        will-change: transform;
        contain: paint;
    }
    .particle.layer2 {
        width: 56vmax;
        height: 40vmax;
        filter: blur(128px);
        opacity: 0.18;
        animation-duration: calc(var(--dur, 120s) * 1.25);
        animation-direction: alternate;
    }

    /* Mist floating animation */
    @keyframes float {
        from {
            transform: translate3d(var(--x1), var(--y1), 0)
                rotate(var(--r1, 0deg)) scale(var(--sx1, 1), var(--sy1, 1));
        }
        to {
            transform: translate3d(var(--x2), var(--y2), 0)
                rotate(var(--r2, 22deg))
                scale(var(--sx2, 1.2), var(--sy2, 1.14));
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .particle {
            animation: none;
        }
    }
</style>

<script>
    // --------------------------
    // MIST PARTICLE SETUP
    // --------------------------
    const parts = document.querySelectorAll('.particle');
    const rand = (min: number, max: number) =>
        Math.random() * (max - min) + min;
    parts.forEach((p) => {
        const element = p as HTMLElement;
        const spread = () => rand(-0.28, 1.28) * 100 + '%';
        element.style.setProperty('--x1', spread());
        element.style.setProperty('--y1', spread());
        element.style.setProperty('--x2', spread());
        element.style.setProperty('--y2', spread());
        element.style.setProperty('--r1', rand(-8, 8) + 'deg');
        element.style.setProperty('--r2', rand(8, 22) + 'deg');
        element.style.setProperty('--sx1', rand(0.9, 1.05).toString());
        element.style.setProperty('--sy1', rand(0.9, 1.05).toString());
        element.style.setProperty('--sx2', rand(1.05, 1.2).toString());
        element.style.setProperty('--sy2', rand(1.05, 1.2).toString());
        /* Shorter cycle = faster drifting smoke */
        element.style.animationDuration = rand(28, 42) + 's';
        element.style.animationDelay = -rand(0, 22) + 's';
    });

    // --------------------------
    // MATRIX CODE RAIN (desktop / tablet only)
    // --------------------------
    const DESKTOP_QUERY = '(min-width: 768px)';

    function initMatrixRain() {
        if (document.querySelector('.mist-bg-root--quiet')) return;
        const canvas = document.querySelector<HTMLCanvasElement>('.matrix-rain');
        if (!canvas) return;
        if (!window.matchMedia(DESKTOP_QUERY).matches) return;
        if (canvas.dataset.bound === 'true') return;
        canvas.dataset.bound = 'true';
        const ctx = canvas.getContext('2d', { alpha: true });
        if (!ctx) return;

        const reduceMotion = window.matchMedia(
            '(prefers-reduced-motion: reduce)'
        ).matches;

        // Glyph set: half-width katakana + digits + a few symbols.
        const GLYPHS: string[] = [];
        for (let c = 0xff66; c <= 0xff9d; c++) GLYPHS.push(String.fromCharCode(c));
        for (const c of '0123456789ABCDEF{}[]<>/*=+-$') GLYPHS.push(c);
        const randGlyph = () => GLYPHS[(Math.random() * GLYPHS.length) | 0];

        const FONT_SIZE = 16;
        const TRAIL = 14; // glyphs per falling streak
        const FRAME_MS = 55; // ~18fps, calm rain
        const DPR = Math.min(window.devicePixelRatio || 1, 1.5);

        let columns = 0;
        let drops: { y: number; speed: number; skip: number; head: string }[] = [];
        let viewW = 0;
        let viewH = 0;
        let accent = '#f97316';
        let accentSoft = 'rgba(249,115,22,0.18)';
        let baseAlpha = 0.55;
        let headAlpha = 0.95;

        function readTheme() {
            const isDark = document.documentElement.classList.contains('dark');
            const css = getComputedStyle(document.documentElement);
            const a = css.getPropertyValue('--accent').trim() || (isDark ? '#ff8a3d' : '#f97316');
            accent = a;
            // Build a soft translucent variant for the tail.
            const hex = a.replace('#', '');
            if (hex.length === 6) {
                const r = parseInt(hex.slice(0, 2), 16);
                const g = parseInt(hex.slice(2, 4), 16);
                const b = parseInt(hex.slice(4, 6), 16);
                accentSoft = `rgba(${r},${g},${b},0.16)`;
            } else {
                accentSoft = isDark ? 'rgba(255,138,61,0.16)' : 'rgba(249,115,22,0.16)';
            }
            baseAlpha = isDark ? 0.55 : 0.5;
            headAlpha = isDark ? 0.95 : 0.8;
        }

        function resize() {
            viewW = window.innerWidth;
            viewH = window.innerHeight;
            canvas.width = Math.floor(viewW * DPR);
            canvas.height = Math.floor(viewH * DPR);
            canvas.style.width = viewW + 'px';
            canvas.style.height = viewH + 'px';
            ctx.setTransform(DPR, 0, 0, DPR, 0, 0);
            columns = Math.ceil(viewW / FONT_SIZE);
            drops = new Array(columns).fill(0).map(() => ({
                y: -Math.floor(Math.random() * (viewH / FONT_SIZE)),
                speed: 0.6 + Math.random() * 0.8,
                skip: Math.floor(Math.random() * 6),
                head: randGlyph(),
            }));
        }

        function draw() {
            ctx.clearRect(0, 0, viewW, viewH);
            ctx.font = `${FONT_SIZE}px ui-monospace, "SF Mono", Menlo, Consolas, monospace`;
            ctx.textBaseline = 'top';

            for (let i = 0; i < columns; i++) {
                const drop = drops[i];
                const x = i * FONT_SIZE;

                // Occasionally flicker the head glyph.
                if (Math.random() < 0.08) drop.head = randGlyph();

                for (let k = 0; k < TRAIL; k++) {
                    const gy = (drop.y - k) * FONT_SIZE;
                    if (gy < -FONT_SIZE || gy > viewH) continue;
                    const t = k / TRAIL;
                    const alpha = (1 - t) * baseAlpha;
                    if (k === 0) {
                        ctx.fillStyle = accent;
                        ctx.globalAlpha = headAlpha;
                        ctx.fillText(drop.head, x, gy);
                    } else {
                        ctx.fillStyle = accent;
                        ctx.globalAlpha = alpha;
                        ctx.fillText(randGlyph(), x, gy);
                    }
                }
                ctx.globalAlpha = 1;

                // Advance this column.
                drop.skip++;
                if (drop.skip >= (1 / drop.speed) | 0) {
                    drop.y += 1;
                    drop.skip = 0;
                }
                if (drop.y - TRAIL > viewH / FONT_SIZE) {
                    drop.y = -Math.floor(Math.random() * 20);
                    drop.speed = 0.6 + Math.random() * 0.8;
                }
            }
        }

        // Static single frame for reduced-motion users.
        function drawStatic() {
            ctx.clearRect(0, 0, viewW, viewH);
            ctx.font = `${FONT_SIZE}px ui-monospace, "SF Mono", Menlo, Consolas, monospace`;
            ctx.textBaseline = 'top';
            for (let i = 0; i < columns; i++) {
                const x = i * FONT_SIZE;
                const rows = Math.floor(viewH / FONT_SIZE);
                // Sparse, random scatter — no motion.
                for (let r = 0; r < rows; r += 6) {
                    ctx.fillStyle = accent;
                    ctx.globalAlpha = 0.12 + Math.random() * 0.12;
                    ctx.fillText(randGlyph(), x, r * FONT_SIZE);
                }
            }
            ctx.globalAlpha = 1;
        }

        let rafId = 0;
        let last = 0;
        let running = false;

        function loop(ts: number) {
            if (!running) return;
            if (document.hidden) {
                rafId = requestAnimationFrame(loop);
                return;
            }
            if (ts - last >= FRAME_MS) {
                draw();
                last = ts;
            }
            rafId = requestAnimationFrame(loop);
        }

        function start() {
            if (running) return;
            running = true;
            last = performance.now();
            rafId = requestAnimationFrame(loop);
        }
        function stop() {
            running = false;
            if (rafId) cancelAnimationFrame(rafId);
            rafId = 0;
        }

        readTheme();
        resize();
        if (reduceMotion) {
            drawStatic();
        } else {
            start();
        }

        // Pause animation when the tab is hidden; resume on visible.
        document.addEventListener('visibilitychange', () => {
            if (reduceMotion) return;
            if (document.hidden) stop();
            else start();
        });

        // Throttled resize.
        let resizeTimer: number | undefined;
        window.addEventListener('resize', () => {
            if (resizeTimer) window.clearTimeout(resizeTimer);
            resizeTimer = window.setTimeout(() => {
                resize();
                if (reduceMotion) drawStatic();
            }, 200);
        });
    }

    function scheduleMatrixWhenIdle() {
        const run = () => initMatrixRain();
        if ('requestIdleCallback' in window) {
            requestIdleCallback(run, { timeout: 2000 });
        } else {
            setTimeout(run, 0);
        }
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', scheduleMatrixWhenIdle);
    } else {
        scheduleMatrixWhenIdle();
    }

    // Lazily start the rain if the viewport grows to desktop/tablet after load.
    let resizeToDesktopTimer: number | undefined;
    window.addEventListener('resize', () => {
        if (resizeToDesktopTimer) window.clearTimeout(resizeToDesktopTimer);
        resizeToDesktopTimer = window.setTimeout(() => {
            if (window.matchMedia(DESKTOP_QUERY).matches) {
                initMatrixRain();
            }
        }, 250);
    });

    // --------------------------
    // THEME CHANGE LISTENER
    // --------------------------
    const observer = new MutationObserver((mutations) => {
        mutations.forEach((mutation) => {
            if (
                mutation.type === 'attributes' &&
                mutation.attributeName === 'class'
            ) {
                // Theme changed, update data-theme attribute
                const isDark =
                    document.documentElement.classList.contains('dark');
                const newTheme = isDark ? 'dark' : 'light';
                document.body.setAttribute('data-theme', newTheme);
            }
        });
    });

    // Start observing the document element for class changes
    observer.observe(document.documentElement, {
        attributes: true,
        attributeFilter: ['class'],
    });
</script>
