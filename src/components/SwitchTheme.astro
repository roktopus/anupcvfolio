---
interface Props {
    className?: string;
}

const { className = '' } = Astro.props;
---

<button
    type="button"
    class:list={['theme-toggle cv-glass cv-theme-toggle', className]}
    aria-label="Switch theme"
>
    <span class="theme-icon theme-icon-sun" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="4"></circle>
            <path d="M12 2v2"></path>
            <path d="M12 20v2"></path>
            <path d="m4.93 4.93 1.41 1.41"></path>
            <path d="m17.66 17.66 1.41 1.41"></path>
            <path d="M2 12h2"></path>
            <path d="M20 12h2"></path>
            <path d="m6.34 17.66-1.41 1.41"></path>
            <path d="m19.07 4.93-1.41 1.41"></path>
        </svg>
    </span>
    <span class="theme-icon theme-icon-moon" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path>
        </svg>
    </span>
</button>

<style>
    .cv-theme-toggle {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 38px;
        height: 38px;
        border-radius: 999px;
        cursor: pointer;
        color: var(--palette-700);
        box-shadow: var(--shadow-card);
        transition: color 0.2s ease, border-color 0.2s ease, background 0.2s ease, transform 0.15s ease;
    }
    .cv-theme-toggle:hover {
        color: var(--accent-strong);
        border-color: var(--border-strong);
    }
    .cv-theme-toggle:active {
        transform: scale(0.96);
    }
    .theme-icon {
        display: inline-flex;
        line-height: 0;
    }
    /* Sun visible in light theme, moon visible in dark theme */
    .theme-icon-moon {
        display: none;
    }
    :global(html.dark) .theme-icon-sun {
        display: none;
    }
    :global(html.dark) .theme-icon-moon {
        display: inline-flex;
    }
    @media (max-width: 480px) {
        .cv-theme-toggle {
            width: 34px;
            height: 34px;
        }
    }
</style>

<script is:inline>
    (function () {
        var THEME_KEY = 'theme';
        var buttons = document.querySelectorAll('.theme-toggle');
        if (!buttons.length) return;

        function applyAria() {
            var dark = document.documentElement.classList.contains('dark');
            var label = dark ? 'Switch to light theme' : 'Switch to dark theme';
            buttons.forEach(function (btn) {
                btn.setAttribute('aria-label', label);
            });
        }

        applyAria();

        buttons.forEach(function (btn) {
            btn.addEventListener('click', function () {
                var dark = document.documentElement.classList.toggle('dark');
                try {
                    localStorage.setItem(THEME_KEY, dark ? 'dark' : 'light');
                } catch (e) {}
                applyAria();
            });
        });
    })();
</script>
