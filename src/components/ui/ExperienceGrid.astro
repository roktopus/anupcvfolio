---

<section
    class="experience-chronicles cv-defer-layout not-prose flex flex-col gap-6"
    aria-labelledby="experience-chronicles-title"
>
    <h2
        id="experience-chronicles-title"
        class="text-headings text-lg font-semibold magic-text"
    >
        📜 Chronicles of Battle & Craft Across Digital Kingdoms
    </h2>

    <div class="flex flex-col gap-4">
        <!-- Companies Section -->
        <div
            class="experience-chronicles__row flex flex-col gap-3 rounded-xl border border-border/60 bg-muted/15 px-3 py-3 shadow-sm sm:flex-row sm:items-start sm:justify-between sm:gap-4 sm:px-4 sm:py-3.5"
        >
            <span
                class="text-sm font-medium text-headings sm:mt-0.5 sm:max-w-[11rem] sm:shrink-0"
                >Companies</span
            >
            <div
                class="experience-chronicles__icons flex min-w-0 flex-1 flex-wrap gap-3 sm:justify-end"
            >
                {
                    companies.map(async (company) => {
                        const logoImage = await getCompanyLogo(
                            company.data.logo
                        );
                        return (
                            <a
                                href={company.data.url}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="group relative p-2 rounded-lg hover:bg-muted-foreground/20 transition-colors shrink-0"
                                title={company.data.name}
                            >
                                <img
                                    src={logoImage.src}
                                    alt={`${company.data.name} Logo`}
                                    width={24}
                                    height={24}
                                    loading="lazy"
                                    decoding="async"
                                    class="w-6 h-6 shrink-0 object-contain opacity-70 group-hover:opacity-100 transition-opacity"
                                />
                            </a>
                        );
                    })
                }
            </div>
        </div>

        <!-- Certifications Section -->
        <div
            class="experience-chronicles__row flex flex-col gap-3 rounded-xl border border-border/60 bg-muted/15 px-3 py-3 shadow-sm sm:flex-row sm:items-start sm:justify-between sm:gap-4 sm:px-4 sm:py-3.5"
        >
            <span
                class="text-sm font-medium text-headings sm:mt-0.5 sm:max-w-[11rem] sm:shrink-0"
                >Certifications</span
            >
            <div
                class="experience-chronicles__icons flex min-w-0 flex-1 flex-wrap gap-3 sm:justify-end"
            >
                {
                    certifications.map(async (certification) => {
                        const iconImage = await getCertificationIcon(
                            certification.data.icon
                        );
                        return (
                            <div
                                class="group relative p-2 rounded-lg hover:bg-muted-foreground/20 transition-colors shrink-0"
                                title={certification.data.name}
                            >
                                {iconImage.src.startsWith('http') ||
                                iconImage.src.startsWith('data:') ? (
                                    <img
                                        src={iconImage.src}
                                        alt={certification.data.name}
                                        class="w-6 h-6 shrink-0 opacity-70 group-hover:opacity-100 transition-opacity"
                                    />
                                ) : (
                                    <Image
                                        src={iconImage.src}
                                        alt={certification.data.name}
                                        width={24}
                                        height={24}
                                        class="w-6 h-6 shrink-0 opacity-70 group-hover:opacity-100 transition-opacity"
                                    />
                                )}
                            </div>
                        );
                    })
                }
            </div>
        </div>

        <!-- Patents Section -->
        <div
            class="experience-chronicles__row flex flex-col gap-3 rounded-xl border border-border/60 bg-muted/15 px-3 py-3 shadow-sm sm:flex-row sm:items-start sm:justify-between sm:gap-4 sm:px-4 sm:py-3.5"
        >
            <span
                class="text-sm font-medium text-headings sm:mt-0.5 sm:max-w-[11rem] sm:shrink-0"
                >Patents</span
            >
            <div
                class="experience-chronicles__icons flex min-w-0 flex-1 flex-wrap gap-3 sm:justify-end"
            >
                <a
                    href="https://image-ppubs.uspto.gov/dirsearch-public/print/downloadPdf/20240019995"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="group relative p-2 rounded-lg hover:bg-muted-foreground/20 transition-colors shrink-0"
                    title="USER INTERFACE (UI) FOR POWER SYSTEM CONTROLLER DEVICE"
                >
                    <div
                        class="w-6 h-6 text-blue-600 opacity-70 group-hover:opacity-100 transition-opacity"
                        set:html={PATENT_ICON_SVG}
                    />
                </a>
            </div>
        </div>

        <!-- Cloud Platforms Section -->
        <div
            class="experience-chronicles__row flex flex-col gap-3 rounded-xl border border-border/60 bg-muted/15 px-3 py-3 shadow-sm sm:flex-row sm:items-start sm:justify-between sm:gap-4 sm:px-4 sm:py-3.5"
        >
            <span
                class="text-sm font-medium text-headings sm:mt-0.5 sm:max-w-[11rem] sm:shrink-0"
                >Cloud Platforms</span
            >
            <div
                class="experience-chronicles__icons flex min-w-0 flex-1 flex-wrap gap-3 sm:justify-end"
            >
                {
                    cloudPlatformsDisplay.map(({ entry: platform, resolvedIcon }) => (
                        <a
                            href={platform.data.url}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="group relative p-2 rounded-lg hover:bg-muted-foreground/20 transition-colors shrink-0"
                            title={platform.data.name}
                        >
                            {resolvedIcon.kind === 'remote' ? (
                                <img
                                    src={resolvedIcon.src}
                                    alt={`${platform.data.name} Logo`}
                                    class="w-6 h-6 shrink-0 opacity-70 group-hover:opacity-100 transition-opacity"
                                />
                            ) : (
                                <Image
                                    src={resolvedIcon.src}
                                    alt={`${platform.data.name} Logo`}
                                    width={24}
                                    height={24}
                                    class="w-6 h-6 shrink-0 opacity-70 group-hover:opacity-100 transition-opacity"
                                />
                            )}
                        </a>
                    ))
                }
            </div>
        </div>

        <!-- Programming Languages Section -->
        <div
            class="experience-chronicles__row flex flex-col gap-3 rounded-xl border border-border/60 bg-muted/15 px-3 py-3 shadow-sm sm:flex-row sm:items-start sm:justify-between sm:gap-4 sm:px-4 sm:py-3.5"
        >
            <span
                class="text-sm font-medium text-headings sm:mt-0.5 sm:max-w-[11rem] sm:shrink-0"
                >Programming Languages</span
            >
            <div
                class="experience-chronicles__icons flex min-w-0 flex-1 flex-wrap gap-3 sm:justify-end"
            >
