---
import Container from '@/components/Container.astro';
import Avatar from '@/components/ui/Avatar.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { DEFAULT_CONFIGURATION } from '@/lib/constants';
import { formatDate } from '@/lib/utils';
import { deriveCategory } from '@/lib/post-meta';
import PortfolioIcon from '@/components/ui/PortfolioIcon.astro';
import { Image, getImage } from 'astro:assets';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('posts');

  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, remarkPluginFrontmatter } = await render(entry);
const heroImage = entry.data.image
  ? await getImage({
      src: entry.data.image,
      format: 'webp',
      width: 1200,
      height: 675,
    })
  : null;

const category = deriveCategory(entry.id, entry.data.title);
const dateText = formatDate(entry.data.date);
const minutesRead = remarkPluginFrontmatter.minutesRead as string | undefined;
const description = entry.data.seo?.description ?? '';
---

<BaseLayout seo={entry.data.seo}>
  {heroImage && (
    <Fragment slot="head">
      <link
        rel="preload"
        as="image"
        href={heroImage.src}
        imagesizes="(max-width: 768px) 100vw, 768px"
      />
    </Fragment>
  )}

  <Container as="section" wide class="pt-6 sm:pt-10">
    <article class="cv-article flex flex-col gap-6">
      <!-- Back link -->
      <a href="/writing" class="cv-back-link" data-astro-prefetch="hover">
        <PortfolioIcon name="arrow-right" size={15} />
        <span>Back to Scrolls</span>
      </a>

      <!-- Article header -->
      <header class="cv-article-head flex flex-col gap-4">
        <div class="flex items-center gap-3 flex-wrap">
          <span class="cv-cat-tag">{category.toUpperCase()}</span>
          <span class="cv-article-meta-inline text-sm text-muted-foreground flex items-center gap-2 flex-wrap">
            <span class="flex items-center gap-1.5">
              <PortfolioIcon name="bookmark" size={14} />
              {dateText}
            </span>
            {minutesRead && (
              <>
                <span aria-hidden="true">·</span>
                <span>{minutesRead}</span>
              </>
            )}
          </span>
        </div>

        <h1 class="cv-article-title text-3xl sm:text-4xl font-bold tracking-tight text-headings">
          {entry.data.title}
        </h1>

        {description && (
          <p class="cv-article-lead text-base sm:text-lg text-foreground max-w-2xl">
            {description}
          </p>
        )}

        <div class="cv-author-row flex items-center gap-3 pt-1">
          <Avatar />
          <div class="flex flex-col">
            <span class="cv-author-name flex items-center gap-1.5">
              {DEFAULT_CONFIGURATION.author.name}
              <span class="cv-accent-text"><PortfolioIcon name="spark" size={13} /></span>
            </span>
            <span class="cv-author-sub text-sm text-muted-foreground">
              3D Web XR Mixed Reality Engineer from Pune 🇮🇳 • He/Him
            </span>
          </div>
        </div>
      </header>

      <!-- Hero image -->
      {entry.data.image && (
        <div class="cv-article-hero relative aspect-video overflow-hidden">
          <Image
            src={entry.data.image}
            alt={entry.data.title}
            format="webp"
            width={1200}
            height={675}
            sizes="(max-width: 768px) 100vw, 768px"
            loading="eager"
            fetchpriority="high"
            decoding="sync"
            class="object-cover w-full h-full"
          />
        </div>
      )}

      <!-- Prose body -->
      <div class="prose dark:prose-invert cv-prose max-w-none">
        <Content />
      </div>

      <!-- Footer rule + back to scrolls -->
      <footer class="cv-article-footer flex flex-col gap-4 pt-4">
        <hr class="cv-article-rule" />
        <div class="flex items-center justify-between gap-4 flex-wrap">
          <a href="/writing" class="cv-back-link" data-astro-prefetch="hover">
            <PortfolioIcon name="arrow-right" size={15} />
            <span>Back to Scrolls</span>
          </a>
          <a href="/rss.xml" class="cv-rss-mini" aria-label="Subscribe via RSS">
            <PortfolioIcon name="rss" size={15} />
            <span>Subscribe via RSS</span>
          </a>
        </div>
      </footer>
    </article>
  </Container>

  <style is:global>
    .prose pre.chord-sheet {
      margin: 1.25rem 0;
      padding: 1rem 1.1rem;
      border-radius: 0.85rem;
      border: 1px solid color-mix(in oklab, var(--color-border) 65%, transparent);
      background: color-mix(in oklab, var(--color-background) 88%, #111 12%);
      overflow-x: auto;
      line-height: 1.8;
      box-shadow: 0 4px 14px rgba(0, 0, 0, 0.08);
    }

    .dark .prose pre.chord-sheet {
      background: color-mix(in oklab, #0b1020 82%, #000 18%);
      border-color: color-mix(in oklab, var(--color-border) 55%, #334155 45%);
    }

    .prose pre.chord-sheet code {
      display: block;
      font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas,
        'Liberation Mono', 'Courier New', monospace;
      font-size: 0.94rem;
      white-space: pre;
      tab-size: 4;
      color: var(--color-headings);
      background: transparent;
      padding: 0;
    }

    @media (max-width: 768px) {
      .prose pre.chord-sheet {
        padding: 0.85rem 0.9rem;
      }

      .prose pre.chord-sheet code {
        font-size: 0.88rem;
      }
    }

    .youtube-embed {
      position: relative;
      display: block;
      width: 100%;
      max-width: 100%;
      border-radius: 0.75rem;
      overflow: hidden;
      aspect-ratio: 16 / 9;
      margin: 1.25rem 0;
      background: #000;
    }

    .youtube-embed iframe {
      width: 100%;
      height: 100%;
      border: 0;
      display: block;
    }
  </style>

  <style>
    .cv-article {
      max-width: 46rem;
      margin-inline: auto;
    }
    .cv-back-link {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      color: var(--palette-600);
      font-size: 0.88rem;
      font-weight: 600;
      width: max-content;
      transition: color 0.2s ease;
    }
    .cv-back-link :global(svg) {
      transform: rotate(180deg);
      transition: transform 0.2s ease;
    }
    .cv-back-link:hover {
      color: var(--accent-strong);
    }
    .cv-back-link:hover :global(svg) {
      transform: rotate(180deg) translateX(3px);
    }
    .cv-cat-tag {
      display: inline-block;
      padding: 0.25rem 0.55rem;
      border-radius: 6px;
      background: var(--accent-soft);
      color: var(--accent-strong);
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.05em;
    }
    .dark .cv-cat-tag {
      color: var(--accent);
    }
    .cv-article-title {
      line-height: 1.15;
    }
    .cv-article-lead {
      color: var(--palette-600);
      line-height: 1.6;
    }
    .cv-author-name {
      font-weight: 700;
      color: var(--palette-800);
    }
    .cv-author-sub {
      color: var(--palette-600);
    }
    .cv-article-hero {
      border-radius: 16px;
      box-shadow: var(--shadow-card);
      border: 1px solid var(--border-soft);
    }
    .cv-prose {
      color: var(--palette-600);
    }
    .cv-prose :global(a) {
      color: var(--accent-strong);
      text-decoration: underline;
      text-underline-offset: 2px;
    }
    .dark .cv-prose :global(a) {
      color: var(--accent);
    }
    .cv-prose :global(a:hover) {
      color: var(--accent);
    }
    .cv-prose :global(h2) {
      color: var(--palette-800);
      margin-top: 2rem;
    }
    .cv-prose :global(h3) {
      color: var(--palette-800);
      margin-top: 1.5rem;
    }
    .cv-prose :global(strong) {
      color: var(--palette-800);
    }
    .cv-prose :global(blockquote) {
      border-left: 3px solid var(--accent);
      color: var(--palette-600);
    }
    .cv-article-rule {
      border: 0;
      border-top: 1px solid var(--border-soft);
      margin: 0;
    }
    .cv-rss-mini {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      color: var(--accent);
      font-size: 0.85rem;
      font-weight: 600;
    }
    .cv-rss-mini:hover {
      color: var(--accent-strong);
    }

    @media (max-width: 640px) {
      .cv-article-title {
        font-size: 1.85rem;
      }
    }
  </style>

  <script>
    // @ts-nocheck
    function extractYouTubeId(rawUrl) {
      try {
        const url = new URL(rawUrl);
        const host = url.hostname.replace(/^www\./, '');

        if (host === 'youtu.be') {
          return url.pathname.slice(1).split('/')[0] || null;
        }

        if (host === 'youtube.com' || host === 'm.youtube.com') {
          if (url.pathname === '/watch') {
            return url.searchParams.get('v');
          }

          if (url.pathname.startsWith('/shorts/')) {
            return url.pathname.split('/')[2] || null;
          }

          if (url.pathname.startsWith('/embed/')) {
            return url.pathname.split('/')[2] || null;
          }
        }
      } catch {
        return null;
      }

      return null;
    }

    function createYouTubeEmbed(videoId, title) {
      const wrapper = document.createElement('div');
      wrapper.className = 'youtube-embed not-prose';
      wrapper.style.width = '100%';
      wrapper.style.maxWidth = '100%';
      wrapper.style.display = 'block';
      wrapper.style.aspectRatio = '16 / 9';
      wrapper.style.margin = '1.25rem 0';
      wrapper.style.background = '#000';
      wrapper.style.borderRadius = '0.75rem';
      wrapper.style.overflow = 'hidden';

      const iframe = document.createElement('iframe');
      iframe.src = `https://www.youtube.com/embed/${videoId}?rel=0`;
      iframe.allow =
        'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share';
      iframe.referrerPolicy = 'strict-origin-when-cross-origin';
      iframe.allowFullscreen = true;
      iframe.loading = 'lazy';
      iframe.title = title || 'YouTube video player';
      iframe.style.width = '100%';
      iframe.style.height = '100%';
      iframe.style.border = '0';
      iframe.style.display = 'block';

      wrapper.appendChild(iframe);
      return wrapper;
    }

    function hydrateYouTubePreviews() {
      const prose = document.querySelector('article .prose');
      if (!prose) return;

      const anchors = prose.querySelectorAll(
        'a[href*="youtu.be"], a[href*="youtube.com"]'
      );

      anchors.forEach((anchor) => {
        if (anchor.dataset.youtubePreviewApplied === 'true') return;

        const href = anchor.getAttribute('href') || '';
        const videoId = extractYouTubeId(href);
        if (!videoId) return;

        const paragraph = anchor.closest('p');
        const isStandaloneLink =
          paragraph &&
          paragraph.textContent &&
          paragraph.textContent.trim() === anchor.textContent?.trim();

        const embed = createYouTubeEmbed(videoId, anchor.textContent?.trim() || '');

        if (isStandaloneLink && paragraph) {
          paragraph.replaceWith(embed);
        } else {
          anchor.insertAdjacentElement('afterend', embed);
        }

        anchor.dataset.youtubePreviewApplied = 'true';
      });
    }

    function hydrateChordSheets() {
      const prose = document.querySelector('article .prose');
      if (!prose) return;

      const codeBlocks = prose.querySelectorAll('pre code');
      codeBlocks.forEach((codeEl) => {
        const pre = codeEl.closest('pre');
        if (!pre) return;

        const className = codeEl.className || '';
        const isChordLanguage = className.includes('language-chords');
        const looksLikeChordSheet =
          /\([A-G][#bmadsus0-9/]*\)/.test(codeEl.textContent || '') &&
          /\n/.test(codeEl.textContent || '');

        if (isChordLanguage || looksLikeChordSheet) {
          pre.classList.add('chord-sheet');
        }
      });
    }

    hydrateYouTubePreviews();
    hydrateChordSheets();
    document.addEventListener('astro:page-load', hydrateYouTubePreviews);
    document.addEventListener('astro:after-swap', hydrateYouTubePreviews);
    document.addEventListener('astro:page-load', hydrateChordSheets);
    document.addEventListener('astro:after-swap', hydrateChordSheets);
  </script>
</BaseLayout>
